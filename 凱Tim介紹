  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:"Noto Sans TC","Microsoft JhengHei",sans-serif;color:#1d2730;background:#f7f5ef;line-height:1.7}
    a{text-decoration:none;color:inherit}
    img{width:100%;display:block;border-radius:22px}
    .wrap{max-width:1180px;margin:auto;padding:0 22px}
    .gold{color:#c6a35d}
    .btn{display:inline-block;padding:14px 24px;border-radius:999px;background:#c6a35d;color:white;font-weight:800;margin:8px 8px 0 0}
    .btn.dark{background:#16232d}
    header{position:sticky;top:0;z-index:99;background:rgba(255,255,255,.9);backdrop-filter:blur(12px);border-bottom:1px solid #eee}
    nav{height:72px;display:flex;justify-content:space-between;align-items:center}
    nav h2{font-size:22px}
    nav .links a{margin-left:18px;font-weight:700}
    .hero{padding:80px 0;background:linear-gradient(135deg,#fff,#f1e6ca)}
    .hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:45px;align-items:center}
    .tag{display:inline-block;background:#16232d;color:white;padding:7px 16px;border-radius:999px;margin-bottom:18px}
    h1{font-size:54px;line-height:1.15;margin-bottom:18px}
    h1 span{display:block;font-size:30px;margin-top:10px}
    .hero p{font-size:21px;margin-bottom:20px}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:26px}
    .stat{background:white;padding:18px;border-radius:18px;box-shadow:0 10px 25px rgba(0,0,0,.06)}
    .stat b{font-size:28px;color:#c6a35d}
    section{padding:72px 0}
    .title{text-align:center;margin-bottom:40px}
    .title h2{font-size:36px;margin-bottom:10px}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
    .card{background:white;border-radius:24px;padding:28px;box-shadow:0 10px 28px rgba(0,0,0,.07)}
    .card h3{font-size:24px;margin-bottom:12px;color:#16232d}
    .card ul{padding-left:20px}
    .dark-section{background:#16232d;color:white}
    .dark-section .card{background:#22313d;color:white}
    .photo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
    .photo-grid img{height:260px;object-fit:cover}
    .about{display:grid;grid-template-columns:.9fr 1.1fr;gap:36px;align-items:center}
    .about-text{background:white;border-radius:28px;padding:34px}
    .cta{background:linear-gradient(135deg,#16232d,#314353);color:white;text-align:center;border-radius:34px;padding:52px 24px}
    .contact-box{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:28px}
    .contact-item{background:white;color:#16232d;padding:20px;border-radius:20px;font-weight:800}
    footer{text-align:center;padding:30px;background:#111;color:#ddd}
    @media(max-width:850px){
      nav .links{display:none}
      .hero-grid,.about,.cards,.photo-grid,.contact-box,.stats{grid-template-columns:1fr}
      h1{font-size:40px}
      h1 span{font-size:24px}
      .hero{padding:48px 0}
      section{padding:52px 0}
      .photo-grid img{height:auto}
    }
